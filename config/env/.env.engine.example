# ================================================================
# FLOWABLE ENGINE SERVICE CONFIGURATION
# ================================================================
# Service-specific configuration for the Flowable BPM engine.
# Copy to .env.engine and update with actual values.
# Inherits from .env.shared for common infrastructure settings.
# ================================================================

# ----------------------------------------------------------------
# Service Configuration
# ----------------------------------------------------------------
SERVICE_NAME=engine-service
SERVER_PORT=8081

# ----------------------------------------------------------------
# Database Schema
# ----------------------------------------------------------------
SPRING_DATASOURCE_SCHEMA=flowable

# ----------------------------------------------------------------
# Flowable Configuration
# ----------------------------------------------------------------
# Async executor (for timers, async jobs)
FLOWABLE_ASYNC_EXECUTOR_ACTIVATE=true
FLOWABLE_ASYNC_EXECUTOR_CORE_POOL_SIZE=2
FLOWABLE_ASYNC_EXECUTOR_MAX_POOL_SIZE=10

# Database schema management
FLOWABLE_DATABASE_SCHEMA_UPDATE=true

# Process definition cache
FLOWABLE_PROCESS_DEFINITION_CACHE_LIMIT=100

# History level (none, activity, audit, full)
FLOWABLE_HISTORY_LEVEL=full

# Enable REST API
FLOWABLE_REST_API_ENABLED=true

# ----------------------------------------------------------------
# Process Storage
# ----------------------------------------------------------------
# Local directory for storing uploaded BPMN files
BPMN_STORAGE_PATH=./process-definitions

# Maximum BPMN file size (in MB)
BPMN_MAX_FILE_SIZE=5

# ----------------------------------------------------------------
# Service Integration
# ----------------------------------------------------------------
# URLs for other services (used by delegates)
HR_SERVICE_URL=http://localhost:8082
ADMIN_SERVICE_URL=http://localhost:8083

# Service discovery (Future - Phase 3)
# EUREKA_CLIENT_ENABLED=false

# ----------------------------------------------------------------
# Monitoring
# ----------------------------------------------------------------
# Actuator endpoints
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,flowable
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# ----------------------------------------------------------------
# API Documentation
# ----------------------------------------------------------------
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html

# ----------------------------------------------------------------
# SMTP / Email
# ----------------------------------------------------------------
# Dev: Mailpit (included in docker-compose.yml, no credentials needed)
# Prod: replace with your SMTP provider
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false
SMTP_STARTTLS_REQUIRED=false
# Prod SMTP example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=<your-sendgrid-api-key>
# SMTP_AUTH=true
# SMTP_STARTTLS_ENABLE=true
# SMTP_STARTTLS_REQUIRED=true
MAIL_FROM=noreply@werkflow.local

# Set true to open /actuator and /swagger-ui without auth (dev only)
ENGINE_CLIENT_SECRET=REPLACE_WITH_ACTUAL_SECRET
EXPOSE_MANAGEMENT_ENDPOINTS=true
