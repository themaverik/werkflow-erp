# ================================================================
# BUSINESS SERVICE CONFIGURATION
# ================================================================
# Consolidated service hosting HR, Finance, Procurement, and
# Inventory domains under a single Spring Boot process.
# Copy to .env.business and update with actual values.
# Inherits from .env.shared for common infrastructure settings.
# ================================================================

# ----------------------------------------------------------------
# Service Configuration
# ----------------------------------------------------------------
SERVICE_NAME=business-service
SERVER_PORT=8084

# ----------------------------------------------------------------
# Database
# ----------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=werkflow
POSTGRES_USER=werkflow_admin
POSTGRES_PASSWORD=secure_password_change_me

# ----------------------------------------------------------------
# Keycloak OAuth2
# ----------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8090
KEYCLOAK_REALM=werkflow

# ----------------------------------------------------------------
# External Services
# ----------------------------------------------------------------
ENGINE_SERVICE_URL=http://localhost:8081
ADMIN_SERVICE_URL=http://localhost:8083

# ----------------------------------------------------------------
# Logging
# ----------------------------------------------------------------
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=INFO
SQL_LOG_LEVEL=WARN
JPA_SHOW_SQL=false
